# Digital Human Studio — Environment Variables
# Copy this to .env and fill in your values.
# Never commit .env to git.

# ── Server ────────────────────────────────────────
PORT=4200

# ── AI Runtime Mode ───────────────────────────────
# local   = only use local workers (Piper TTS, Wav2Lip, FFmpeg)
# hybrid  = prefer local, fall back to cloud when local workers fail
# cloud   = use cloud APIs exclusively (ElevenLabs, Muapi, etc.)
AI_RUNTIME_MODE=hybrid

# ── TTS Provider ──────────────────────────────────
# piper       = local Piper TTS (free, no internet, requires model download)
# elevenlabs  = ElevenLabs cloud API (high quality, requires API key)
# system      = macOS 'say' command (free, always works on Mac)
TTS_PROVIDER=system

# ── Lip Sync Provider ─────────────────────────────
# wav2lip   = local Wav2Lip (free, requires GPU/CPU + model download)
# sadtalker = local SadTalker (higher quality, slower)
# muapi     = Muapi cloud API (no local setup needed, costs money)
# static    = static image + audio (no real lip sync, but always works)
LIPSYNC_PROVIDER=static

# ── Paths ─────────────────────────────────────────
# Override if FFmpeg/Python are not on PATH
FFMPEG_PATH=ffmpeg
PYTHON_PATH=python3.9

# ── API Keys (optional — only needed for cloud providers) ──
ELEVENLABS_API_KEY=
MUAPI_API_KEY=
GEMINI_API_KEY=

# ── Cloud GPU Worker URL (Phase 2) ────────────────
# Point to a remote worker for GPU-intensive tasks
GPU_WORKER_URL=
